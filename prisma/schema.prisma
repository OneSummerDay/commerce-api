generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("users")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique

  @@map("categories")
}