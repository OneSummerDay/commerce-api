generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("users")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  products  Product[]

  @@map("categories")
}

model Product {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  price       Float
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("products")
}